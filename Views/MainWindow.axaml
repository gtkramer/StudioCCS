<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:StudioCCS.Controls"
        xmlns:vm="clr-namespace:StudioCCS.ViewModels"
        xmlns:views="clr-namespace:StudioCCS.Views"
        x:Class="StudioCCS.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Width="1100" Height="740"
        Title="StudioCCS">

    <DockPanel>
        <!-- Menu -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="Load CCS..." Click="OnLoadClick" />
                <Separator />
                <MenuItem Header="Exit" Click="OnExitClick" />
            </MenuItem>
            <MenuItem Header="_Scene">
                <MenuItem Header="Dump to .OBJ..." Click="OnDumpObjClick" />
                <MenuItem Header="Dump to .SMD..." Name="miDumpSmd" IsVisible="False" Click="OnDumpSmdClick" />
            </MenuItem>
            <MenuItem Header="_Options">
                <MenuItem Header="Default to Axis Movement" ToggleType="CheckBox" IsChecked="{Binding DefaultToAxisMovement, Mode=TwoWay}" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Wireframe" ToggleType="CheckBox" IsChecked="{Binding Wireframe, Mode=TwoWay}" />
                <MenuItem Header="Vertex Colors" ToggleType="CheckBox" IsChecked="{Binding VertexColors, Mode=TwoWay}" />
                <MenuItem Header="Vertex Normals" ToggleType="CheckBox" IsChecked="{Binding VertexNormals, Mode=TwoWay}" />
                <MenuItem Header="Textured" ToggleType="CheckBox" IsChecked="{Binding Textured, Mode=TwoWay}" />
                <Separator />
                <MenuItem Header="Backface Culling" ToggleType="CheckBox" IsChecked="{Binding BackfaceCull, Mode=TwoWay}" />
                <Separator />
                <MenuItem Header="Draw Grid" ToggleType="CheckBox" IsChecked="{Binding DrawGrid, Mode=TwoWay}" />
                <MenuItem Header="Draw Collision Meshes" ToggleType="CheckBox" IsChecked="{Binding DrawCollisionMeshes, Mode=TwoWay}" />
                <MenuItem Header="Draw Dummies" ToggleType="CheckBox" IsChecked="{Binding DrawDummies, Mode=TwoWay}" />
                <MenuItem Header="Draw Light Helpers" ToggleType="CheckBox" IsChecked="{Binding DrawLightHelpers, Mode=TwoWay}" />
                <MenuItem Header="Draw Axis Marker (Viewport)" ToggleType="CheckBox" IsChecked="{Binding DrawAxisViewport, Mode=TwoWay}" />
                <MenuItem Header="Draw Axis Marker (World Center)" ToggleType="CheckBox" IsChecked="{Binding DrawWorldCenter, Mode=TwoWay}" />
            </MenuItem>
        </Menu>

        <!-- Mode toolbar: grouped radio buttons are mutually exclusive by design. -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4" Spacing="8">
            <RadioButton GroupName="ViewMode" Content="Preview" IsChecked="{Binding IsPreviewMode, Mode=TwoWay}" />
            <RadioButton GroupName="ViewMode" Content="Scene" IsChecked="{Binding IsSceneMode, Mode=TwoWay}" />
            <RadioButton GroupName="ViewMode" Content="All" IsChecked="{Binding IsAllMode, Mode=TwoWay}" />
        </StackPanel>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" BorderBrush="#40808080" BorderThickness="0,1,0,0" Padding="6,3">
            <StackPanel Orientation="Horizontal" Spacing="20">
                <TextBlock Text="{Binding RenderModeStatus}" />
                <TextBlock Text="{Binding CameraStatus}" />
            </StackPanel>
        </Border>

        <!-- Main area: tree | viewport, with a resizable log below -->
        <Grid RowDefinitions="*,Auto,160">
            <Grid Grid.Row="0" Name="splitGrid" ColumnDefinitions="240,Auto,*">
                <Panel Grid.Column="0" Name="leftPanel">
                    <TreeView Name="ccsTree"
                              ItemsSource="{Binding CcsRoots}"
                              ItemTemplate="{StaticResource CcsNodeTemplate}"
                              SelectionChanged="OnCcsTreeSelectionChanged"
                              ContextRequested="OnCcsTreeContextRequested" />
                    <Grid Name="scenePanel" IsVisible="False" RowDefinitions="*,Auto,*">
                        <TreeView Grid.Row="0" Name="sceneTree"
                                  ItemsSource="{Binding SceneRoots}"
                                  ItemTemplate="{StaticResource CcsNodeTemplate}"
                                  ContextRequested="OnSceneTreeContextRequested" />
                        <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" />
                        <Border Grid.Row="2" Background="#10808080">
                            <TextBlock Text="(properties)" Opacity="0.5" Margin="6" />
                        </Border>
                    </Grid>
                </Panel>

                <GridSplitter Grid.Column="1" Name="treeSplitter" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch" />

                <!-- The GL surface composites its framebuffer but isn't a reliable
                     hit-test target, so it never receives pointer events. We catch
                     input on a transparent, focusable Border over it and forward to
                     Scene; the GL control is marked input-transparent. -->
                <Border Grid.Column="2" Name="viewportHost"
                        Background="Transparent" Focusable="True"
                        PointerPressed="OnViewportPointerPressed"
                        PointerMoved="OnViewportPointerMoved"
                        PointerReleased="OnViewportPointerReleased"
                        PointerWheelChanged="OnViewportPointerWheel"
                        KeyDown="OnViewportKeyDown"
                        KeyUp="OnViewportKeyUp">
                    <controls:GlViewport Name="glViewport" IsHitTestVisible="False" />
                </Border>
            </Grid>

            <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" />

            <!-- Log console: one colour-coded line per log call, mirroring stdout.
                 A virtualizing ListBox keeps it responsive under heavy logging.
                 The dark background is fixed (not theme-dependent) so the severity
                 colours stay legible regardless of the OS light/dark setting. -->
            <ListBox Grid.Row="2"
                     Name="logView"
                     Background="#1E1E1E"
                     FontFamily="monospace"
                     FontSize="11"
                     SelectionMode="Multiple"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="4,0" />
                        <Setter Property="MinHeight" Value="0" />
                    </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="views:LogLine">
                        <TextBlock Text="{Binding Text}"
                                   Foreground="{Binding Brush}"
                                   TextWrapping="NoWrap" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </DockPanel>
</Window>
