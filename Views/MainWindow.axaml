<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:StudioCCS.Controls"
        xmlns:vm="clr-namespace:StudioCCS.ViewModels"
        xmlns:views="clr-namespace:StudioCCS.Views"
        x:Class="StudioCCS.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Width="1100" Height="740"
        Title="StudioCCS">

    <DockPanel>
        <!-- Top bar: the menu and the view-mode toggle share one row to reclaim the
             empty space that used to sit beside the menu. The radio group is docked
             Right so it hugs the window edge; the Menu is the fill child and takes
             the rest of the row. The radio group's left margin keeps a minimum gap
             from the menu items even as the window narrows. -->
        <DockPanel DockPanel.Dock="Top">
            <!-- Mode toolbar: grouped radio buttons are mutually exclusive by design. -->
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                        Spacing="8" Margin="24,0,8,0" VerticalAlignment="Center">
                <RadioButton GroupName="ViewMode" Content="Preview" IsChecked="{Binding IsPreviewMode, Mode=TwoWay}" />
                <RadioButton GroupName="ViewMode" Content="Scene" IsChecked="{Binding IsSceneMode, Mode=TwoWay}" />
                <RadioButton GroupName="ViewMode" Content="All" IsChecked="{Binding IsAllMode, Mode=TwoWay}" />
            </StackPanel>

            <Menu>
                <MenuItem Header="_File">
                    <MenuItem Header="Load CCS..." Click="OnLoadClick" />
                    <Separator />
                    <MenuItem Header="Exit" Click="OnExitClick" />
                </MenuItem>
                <MenuItem Header="_Scene">
                    <MenuItem Header="Dump to .OBJ..." Click="OnDumpObjClick" />
                    <MenuItem Header="Dump to .SMD..." Name="miDumpSmd" IsVisible="False" Click="OnDumpSmdClick" />
                    <MenuItem Header="Dump Preview to .SMD..." Name="miDumpPreviewSmd" IsVisible="False" Click="OnDumpPreviewSmdClick" />
                </MenuItem>
                <MenuItem Header="_Options">
                    <MenuItem Header="Default to Axis Movement" ToggleType="CheckBox" IsChecked="{Binding DefaultToAxisMovement, Mode=TwoWay}" />
                </MenuItem>
                <MenuItem Header="_View">
                    <MenuItem Header="Wireframe" ToggleType="CheckBox" IsChecked="{Binding Wireframe, Mode=TwoWay}" />
                    <MenuItem Header="Vertex Colors" ToggleType="CheckBox" IsChecked="{Binding VertexColors, Mode=TwoWay}" />
                    <MenuItem Header="Vertex Normals" ToggleType="CheckBox" IsChecked="{Binding VertexNormals, Mode=TwoWay}" />
                    <MenuItem Header="Textured" ToggleType="CheckBox" IsChecked="{Binding Textured, Mode=TwoWay}" />
                    <Separator />
                    <MenuItem Header="Backface Culling" ToggleType="CheckBox" IsChecked="{Binding BackfaceCull, Mode=TwoWay}" />
                    <Separator />
                    <MenuItem Header="Draw Grid" ToggleType="CheckBox" IsChecked="{Binding DrawGrid, Mode=TwoWay}" />
                    <MenuItem Header="Draw Collision Meshes" ToggleType="CheckBox" IsChecked="{Binding DrawCollisionMeshes, Mode=TwoWay}" />
                    <MenuItem Header="Draw Bounding Boxes" ToggleType="CheckBox" IsChecked="{Binding DrawBoundingBoxes, Mode=TwoWay}" />
                    <MenuItem Header="Draw Dummies" ToggleType="CheckBox" IsChecked="{Binding DrawDummies, Mode=TwoWay}" />
                    <MenuItem Header="Draw Light Helpers" ToggleType="CheckBox" IsChecked="{Binding DrawLightHelpers, Mode=TwoWay}" />
                    <MenuItem Header="Draw Axis Marker (Viewport)" ToggleType="CheckBox" IsChecked="{Binding DrawAxisViewport, Mode=TwoWay}" />
                    <MenuItem Header="Draw Axis Marker (World Center)" ToggleType="CheckBox" IsChecked="{Binding DrawWorldCenter, Mode=TwoWay}" />
                </MenuItem>
            </Menu>
        </DockPanel>

        <!-- Load progress bar: docked at the very bottom of the window and only
             shown while a file-load batch is in flight. It advances one step as
             each file finishes fully loading (GL upload done), so it tracks real
             completion rather than parse start. Stretches the full window width;
             styled to match the status bars. -->
        <Border DockPanel.Dock="Bottom"
                IsVisible="{Binding IsLoading}"
                Background="{DynamicResource StatusBarBackground}"
                BorderBrush="{DynamicResource StatusBarBorder}"
                BorderThickness="0,1,0,0" Padding="10,4">
            <ProgressBar Minimum="0"
                         Maximum="{Binding TotalCount}"
                         Value="{Binding LoadedCount}"
                         Height="14"
                         HorizontalAlignment="Stretch" />
        </Border>

        <!-- Main area: tree | viewport, with a resizable log below -->
        <Grid RowDefinitions="*,Auto,160">
            <Grid Grid.Row="0" Name="splitGrid" ColumnDefinitions="240,Auto,*">
                <Panel Grid.Column="0" Name="leftPanel">
                    <TreeView Name="ccsTree"
                              ItemsSource="{Binding CCSRoots}"
                              ItemTemplate="{StaticResource CCSNodeTemplate}"
                              SelectionChanged="OnCCSTreeSelectionChanged"
                              ContextRequested="OnCCSTreeContextRequested" />
                    <Grid Name="scenePanel" IsVisible="False" RowDefinitions="*,Auto,*">
                        <TreeView Grid.Row="0" Name="sceneTree"
                                  ItemsSource="{Binding SceneRoots}"
                                  ItemTemplate="{StaticResource CCSNodeTemplate}"
                                  ContextRequested="OnSceneTreeContextRequested" />
                        <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" />
                        <Border Grid.Row="2" Background="#10808080">
                            <TextBlock Text="(properties)" Opacity="0.5" Margin="6" />
                        </Border>
                    </Grid>
                </Panel>

                <GridSplitter Grid.Column="1" Name="treeSplitter" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch" />

                <!-- Viewport column: GL surface on top, render-info status bar docked
                     directly beneath it so the camera/mode readout stays grouped with
                     what it describes (rather than spanning the whole window). -->
                <DockPanel Grid.Column="2">
                    <!-- Top bar: render mode. Kept above the viewport because the mode
                         list grows as more views are toggled on, so it needs the full
                         viewport width rather than sharing a line with the camera. -->
                    <Border DockPanel.Dock="Top" Background="{DynamicResource StatusBarBackground}"
                            BorderBrush="{DynamicResource StatusBarBorder}" BorderThickness="0,0,0,1" Padding="10,4">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Mode" Foreground="{DynamicResource StatusBarLabel}" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding RenderModeStatus}"
                                       FontWeight="SemiBold" Foreground="{DynamicResource StatusBarValue}"
                                       TextWrapping="NoWrap" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <!-- Bottom bar: live camera readout. Each value sits in a
                         fixed-width, right-aligned box so the columns stay put as the
                         numbers change ~10x/sec, instead of relying on a monospace
                         font. Labels and values match the top Mode bar (dark value
                         colour, SemiBold). Base spacing is 8 so the gap after "Camera"
                         matches the Mode bar; the Target/Dist labels add left margin to
                         set the Rot/Target/Dist groups slightly further apart. -->
                    <Border DockPanel.Dock="Bottom" Background="{DynamicResource StatusBarBackground}"
                            BorderBrush="{DynamicResource StatusBarBorder}" BorderThickness="0,1,0,0" Padding="10,4">
                        <Border.Styles>
                            <Style Selector="TextBlock.camLabel">
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="Foreground" Value="{DynamicResource StatusBarValue}" />
                                <Setter Property="VerticalAlignment" Value="Center" />
                            </Style>
                            <Style Selector="TextBlock.camValue">
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="Foreground" Value="{DynamicResource StatusBarValue}" />
                                <Setter Property="VerticalAlignment" Value="Center" />
                                <Setter Property="TextAlignment" Value="Right" />
                                <Setter Property="TextWrapping" Value="NoWrap" />
                                <Setter Property="Width" Value="44" />
                            </Style>
                        </Border.Styles>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Camera" Foreground="{DynamicResource StatusBarLabel}" VerticalAlignment="Center" />
                            <TextBlock Classes="camLabel" Text="Rot" />
                            <TextBlock Classes="camValue" Text="{Binding CamRotX}" />
                            <TextBlock Classes="camValue" Text="{Binding CamRotY}" />
                            <TextBlock Classes="camValue" Text="{Binding CamRotZ}" />
                            <TextBlock Classes="camLabel" Text="Target" Margin="55,0,0,0" />
                            <TextBlock Classes="camValue" Text="{Binding CamTargetX}" />
                            <TextBlock Classes="camValue" Text="{Binding CamTargetY}" />
                            <TextBlock Classes="camValue" Text="{Binding CamTargetZ}" />
                            <TextBlock Classes="camLabel" Text="Dist" Margin="55,0,0,0" />
                            <TextBlock Classes="camValue" Text="{Binding CamDistance}" />
                        </StackPanel>
                    </Border>

                    <!-- The GL surface composites its framebuffer but isn't a reliable
                         hit-test target, so it never receives pointer events. We catch
                         input on a transparent, focusable Border over it and forward to
                         Scene; the GL control is marked input-transparent. -->
                    <Border Name="viewportHost"
                            Background="Transparent" Focusable="True"
                            PointerPressed="OnViewportPointerPressed"
                            PointerMoved="OnViewportPointerMoved"
                            PointerReleased="OnViewportPointerReleased"
                            PointerWheelChanged="OnViewportPointerWheel"
                            KeyDown="OnViewportKeyDown"
                            KeyUp="OnViewportKeyUp">
                        <controls:GlViewport Name="glViewport" IsHitTestVisible="False" />
                    </Border>
                </DockPanel>
            </Grid>

            <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" />

            <!-- Log console: one colour-coded line per log call, mirroring stdout.
                 A virtualizing ListBox keeps it responsive under heavy logging.
                 Background reuses StatusBarBackground so the panel matches the
                 bars above and below the viewport; the severity colours come from
                 the theme-aware Log* resources (see App.axaml). The code-behind
                 tails the view to the newest line by setting the ScrollViewer
                 offset (never ScrollIntoView), so there is no forced layout pass
                 to crash under heavy logging.

                 AutoScrollToSelectedItem is off by design: in a log you click a
                 line to read or copy it, and the view jerking to re-centre that
                 line would be hostile. (It also happens to keep selection off the
                 ScrollIntoView path entirely.) -->
            <ListBox Grid.Row="2"
                     Name="logView"
                     Background="{DynamicResource StatusBarBackground}"
                     FontFamily="monospace"
                     FontSize="11"
                     SelectionMode="Multiple"
                     AutoScrollToSelectedItem="False"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="4,0" />
                        <Setter Property="MinHeight" Value="0" />
                    </Style>
                    <!-- The tag's colour is its severity. Default is the neutral
                         LogForeground (info/trace/debug); the warn/error classes,
                         toggled per line by LogLine.IsWarn/IsError, override it.
                         No local Foreground is set on the tag so these style
                         setters win, and they use DynamicResource so a theme
                         switch recolours every line live. -->
                    <Style Selector="TextBlock.tag">
                        <Setter Property="Foreground" Value="{DynamicResource LogForeground}" />
                    </Style>
                    <Style Selector="TextBlock.tag.warn">
                        <Setter Property="Foreground" Value="{DynamicResource LogWarn}" />
                    </Style>
                    <Style Selector="TextBlock.tag.error">
                        <Setter Property="Foreground" Value="{DynamicResource LogError}" />
                    </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                    <!-- Only the severity tag is coloured; ": " and the message are
                         the neutral LogForeground, mirroring the console. -->
                    <DataTemplate x:DataType="views:LogLine">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Classes="tag" Classes.warn="{Binding IsWarn}" Classes.error="{Binding IsError}"
                                       Text="{Binding Tag}" TextWrapping="NoWrap" />
                            <TextBlock Text=": " Foreground="{DynamicResource LogForeground}" />
                            <TextBlock Text="{Binding Message}" Foreground="{DynamicResource LogForeground}" TextWrapping="NoWrap" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </DockPanel>
</Window>
