<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ccs="clr-namespace:StudioCCS"
             x:Class="StudioCCS.App"
             RequestedThemeVariant="Default">

    <Application.Resources>
        <ResourceDictionary>
            <!-- Status-bar palette, keyed by theme variant so the Mode/Camera bars
                 track the OS light/dark setting (DynamicResource re-resolves these
                 live on a theme switch). The Dark values preserve the original look;
                 the Light values are tuned to sit against a light UI.

                 The Log* keys are the log panel's own theme-aware palette. It is
                 deliberately separate from the console's fixed LogPalette: a
                 terminal is virtually always dark, but the panel sits in a themed
                 window, so its neutral text and severity hues must flip with the
                 theme (light-grey "info" text is invisible on a light panel, and
                 the bright orange/red read poorly there too). Dark mirrors the
                 console colours exactly, so dark mode is unchanged; Light uses
                 darker text and deeper amber/red. The panel's *background* reuses
                 StatusBarBackground so it matches the bars above and below it by
                 construction. -->
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="StatusBarBackground" Color="#202020" />
                    <SolidColorBrush x:Key="StatusBarBorder" Color="#40808080" />
                    <SolidColorBrush x:Key="StatusBarLabel" Color="#808890" />
                    <SolidColorBrush x:Key="StatusBarValue" Color="#E0E0E0" />
                    <SolidColorBrush x:Key="LogForeground" Color="#DCDCDC" />
                    <SolidColorBrush x:Key="LogWarn" Color="#FFA500" />
                    <SolidColorBrush x:Key="LogError" Color="#FF5555" />
                    <SolidColorBrush x:Key="TreeNodeMissing" Color="#FF5555" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="StatusBarBackground" Color="#ECECEC" />
                    <SolidColorBrush x:Key="StatusBarBorder" Color="#40606060" />
                    <SolidColorBrush x:Key="StatusBarLabel" Color="#5A6168" />
                    <SolidColorBrush x:Key="StatusBarValue" Color="#202428" />
                    <SolidColorBrush x:Key="LogForeground" Color="#202428" />
                    <SolidColorBrush x:Key="LogWarn" Color="#B35900" />
                    <SolidColorBrush x:Key="LogError" Color="#C42B1C" />
                    <SolidColorBrush x:Key="TreeNodeMissing" Color="#C42B1C" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <!-- Shared template for every CCSTreeNode tree (CCS objects, scene
                 animations, clump bones). Recurses children via Nodes. -->
            <TreeDataTemplate x:Key="CCSNodeTemplate" x:DataType="ccs:CCSTreeNode" ItemsSource="{Binding Nodes}">
                <TextBlock Text="{Binding Text}" Classes.missingNode="{Binding IsMissing}" />
            </TreeDataTemplate>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <!-- Dangling CCS object references (Util.NonExistantNode) render red so a
             broken reference stands out in the tree, the way the original WinForms
             ForeColor did. DynamicResource so the colour tracks the light/dark theme. -->
        <Style Selector="TextBlock.missingNode">
            <Setter Property="Foreground" Value="{DynamicResource TreeNodeMissing}" />
        </Style>
    </Application.Styles>

</Application>
